# Anchor Configuration
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# Your wallet keypair path
WALLET_KEYPAIR_PATH=~/.config/solana/id.json

# ------------------------------------------------------------
# Live Micro-Markets (DEVNET MVP foundation) - safe defaults
# ------------------------------------------------------------
# Master flag (must be true to enable any live micro flow)
ENABLE_LIVE_MICRO_MARKETS=false
# Keep true for this phase so non-devnet refuses to run
LIVE_MICRO_MARKETS_DEV_ONLY=true
# Dedicated operator wallet gate
LIVE_MICRO_OPERATOR_ENABLED=false
# Hard cluster allow-list for live micro routes/engine
LIVE_MICRO_ALLOWED_CLUSTER=devnet
# Dedicated operator private key (server-only)
# Supported formats:
# - bs58-encoded 64-byte secret key
# - JSON array [..64 bytes..]
LIVE_MICRO_OPERATOR_PRIVATE_KEY=
# Optional protected trigger token for server-to-server calls
LIVE_MICRO_TRIGGER_TOKEN=
# Optional window override (minutes, clamped 1..15, default 5)
LIVE_MICRO_WINDOW_MINUTES=5
# Optional operator RPC override (defaults to existing RPC envs)
LIVE_MICRO_RPC_URL=

# Soccer loop controls (activation + rolling 5m windows)
LIVE_MICRO_SOCCER_FIRST_HALF_MAX_MARKETS=9
LIVE_MICRO_SOCCER_SECOND_HALF_MAX_MARKETS=9
LIVE_MICRO_SOCCER_HALFTIME_PAUSE_MINUTES=20
LIVE_MICRO_SOCCER_HARD_STOP_MINUTE=118
LIVE_MICRO_SOCCER_HARD_STOP_MAX_MATCH_MINUTES=130
# Soft cap for concurrently activated loops
LIVE_MICRO_MAX_ACTIVE_MATCH_LOOPS=3

# Dev/local auto scheduler (no external cron needed)
# Default behavior in code: enabled in non-production unless explicitly set false.
LIVE_MICRO_AUTO_TICK_ENABLED=true
# Recommended 10s-20s for localhost/dev.
LIVE_MICRO_AUTO_TICK_INTERVAL_MS=15000
# Max loops processed per interval tick.
LIVE_MICRO_AUTO_TICK_LIMIT=20
# Run one immediate tick at scheduler startup.
LIVE_MICRO_AUTO_TICK_RUN_ON_START=true
# Extra scheduler logs for debugging.
LIVE_MICRO_AUTO_TICK_VERBOSE=true
